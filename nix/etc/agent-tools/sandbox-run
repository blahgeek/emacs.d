#!/usr/bin/env bash
# -*- mode: sh; -*-

set -eo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
if [[ ! -v SKILLS_DIR ]]; then
    echo "SKILLS_DIR is not set"
    exit 1
fi

if [[ -f ~/.profile.agents ]]; then
    source ~/.profile.agents
fi

# The "$1" should set the following variables:
#   - sandbox_rw_files: array of files/dirs to bind read-write (optional)
#   - sandbox_extra_args: extra arguments to pass to the CLI tool (optional)
#   - sandbox_required_apikeys: array of "<ENV_VAR>:<domain>[:<user>]" entries, the
#     domains are fetched in one batch via emacs-auth-source-get and exported
#     as the corresponding env vars (optional)
helper_path="$1"
shift

# The CLI tool to run (required)
exe_path="$1"
shift

if [[ "$*" == "--version" ]]; then
    exec "$exe_path" --version
fi

source "$helper_path"

unset SKILLS_DIR

# skip bwrap if it's already running in sandbox
if [ "${INSIDE_SANDBOX}" = "true" ]; then
    exec "$exe_path" "${sandbox_extra_args[@]}" "$@"
fi

if [[ ! -v sandbox_required_apikeys ]]; then
    sandbox_required_apikeys=()
fi
if [[ ! -v sandbox_extra_args ]]; then
    sandbox_extra_args=()
fi
if [[ ! -v sandbox_rw_files ]]; then
    sandbox_rw_files=()
fi

# Always include the tavily api key (all agents can use it via the tavily skill).
sandbox_required_apikeys+=(
    "TAVILY_API_KEY:api.tavily.com"
    "GH_TOKEN:api.github.com:blahgeek^agent-ro"
)

# Resolve all required api keys in a single emacs-auth-source-get call.
if (( ${#sandbox_required_apikeys[@]} > 0 )); then
    _apikey_vars=()
    _apikey_domains=()
    for _spec in "${sandbox_required_apikeys[@]}"; do
        _apikey_vars+=("${_spec%%:*}")
        _apikey_domains+=("${_spec#*:}")
    done
    mapfile -t _apikey_values < <(emacs-auth-source-get.py "${_apikey_domains[@]}")
    for _i in "${!_apikey_vars[@]}"; do
        _val="${_apikey_values[$_i]:-}"
        if [[ -n "$_val" && "$_val" != "null" ]]; then
            export "${_apikey_vars[$_i]}=$_val"
        fi
    done
    unset _apikey_vars _apikey_domains _apikey_values _spec _i _val
fi

export EDITOR=emacsclient-on-current-server
mkdir -p ~/tmp

prefix_args=(
    bwrap
    --setenv INSIDE_SANDBOX true
    --unshare-pid
    --dev /dev
    --proc /proc
    --die-with-parent
    --ro-bind /usr /usr
    --ro-bind /etc /etc
    --ro-bind-try /bin /bin
    --ro-bind-try /sbin /sbin
    --ro-bind-try /lib /lib
    --ro-bind-try /lib64 /lib64
    --ro-bind-try /nix /nix
    --ro-bind-try /var/nix /var/nix
    --bind-try /var/run/docker.sock /var/run/docker.sock
    # /tmp is also required for EDITOR to work (because agent would open file under tmp)
    --bind /tmp /tmp
    --tmpfs /home
    --ro-bind-try ~/Code ~/Code
    --ro-bind-try ~/work ~/work
    --bind-try ~/.local/share/uv ~/.local/share/uv
    --bind-try ~/.local/share/agents ~/.local/share/agents
    --bind-try ~/.cache ~/.cache
    --bind-try ~/.npm ~/.npm
    --bind-try ~/.npm-packages ~/.npm-packages
    --bind-try ~/.cargo ~/.cargo
    --bind-try ~/.rustup ~/.rustup
    --bind-try ~/.gyro ~/.gyro
    --bind-try ~/.docker ~/.docker
    --bind-try ~/.lark-cli ~/.lark-cli
    --bind-try ~/.local/share/lark-cli ~/.local/share/lark-cli
    --ro-bind-try ~/.local/state ~/.local/state
    --ro-bind-try ~/.nix-profile ~/.nix-profile
    --ro-bind-try ~/.nix-defexpr ~/.nix-defexpr
    --ro-bind-try ~/.nix-channels ~/.nix-channels
    --ro-bind-try ~/.local/bin ~/.local/bin
    --bind-try ~/tmp ~/tmp
)

# bind emacs server sockets if available
for _sock in "$EMACS_SERVER_SOCKET" "$EMACS_SAFESERVER_SOCKET"; do
    [[ -n "$_sock" && -S "$_sock" ]] && prefix_args+=(--ro-bind "$_sock" "$_sock")
done

# if /etc/resolv.conf is a symlink and points to dirs other than /etc/, add a --ro-bind for the actual file
if [[ -L /etc/resolv.conf ]]; then
    target="$(readlink -f /etc/resolv.conf)"
    if [[ "$target" != /etc/* ]]; then
        prefix_args+=(--ro-bind "$target" "$target")
    fi
fi

# Add tool-specific read-write bindings
for item in "${sandbox_rw_files[@]}"; do
    if [[ "$item" == *:* ]]; then
        prefix_args+=(--bind-try "${item%%:*}" "${item#*:}")
    else
        prefix_args+=(--bind-try "$item" "$item")
    fi
done

if [[ "$PWD" == "$HOME" || "$PWD" == "$HOME/Code" || "$PWD" == "$HOME/work" ]]; then
    mkdir -p ~/agent-workspace
    cd "$(mktemp -d ~/agent-workspace/$(date +%Y%m%d)-XXXXXX)"
fi

echo "Using bwrap with only $PWD writable... YOLO!"
prefix_args+=(
    # NOTE: .git is writable, but .jj is not! rely on jj's op log and jj is only for me!
    --bind "$PWD" "$PWD"
    --ro-bind-try "$PWD/.jj" "$PWD/.jj"
)

# if "$@" does not contain "--mode rpc"
if [[ "$*" != *"--mode rpc"* ]]; then
    # https://github.com/containers/bubblewrap/issues/369#issuecomment-620176048
    prefix_args+=(
        -- "$SCRIPT_DIR"/setpgrp-wrapper
    )
fi

exec "${prefix_args[@]}" "$exe_path" "${sandbox_extra_args[@]}" "$@"
