#!/bin/bash

if [ $# -eq 0 ]; then
    echo "No arguments provided"
    exit 1
fi

result=$(jq -n '["auth-source-get", [$ARGS.positional[] | [., "apikey"]]]' --args "$@" | emacs-safeclient)

if ! echo "$result" | jq -e 'type == "array"' > /dev/null 2>&1; then
    echo "$result" >&2
    exit 1
fi

echo "$result" | jq -r '.[]'
